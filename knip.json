{
  "$schema": "./node_modules/knip/schema.json",
  "entry": [
    "entrypoints/**/*.{ts,tsx}",
    "components/**/*.{test,stories}.{ts,tsx}",
    "features/**/*.{test,stories}.{ts,tsx}",
    "hooks/**/*.{test,stories}.{ts,tsx}",
    "lib/**/*.{test,stories}.{ts,tsx}",
    "utils/**/*.{test,stories}.{ts,tsx}",
    "e2e/**/*.{ts,tsx}",
    ".storybook/**/*.{ts,tsx}",
    "vitest.config.ts",
    "vitest.ci.config.ts",
    "vitest.workspace.ts",
    "wxt.config.ts"
  ],
  "project": [
    "components/**/*.{ts,tsx}",
    "constants/**/*.ts",
    "entrypoints/**/*.{ts,tsx}",
    "e2e/**/*.{ts,tsx}",
    "features/**/*.{ts,tsx}",
    "hooks/**/*.{ts,tsx}",
    "lib/**/*.{ts,tsx}",
    "types/**/*.{ts,tsx,d.ts}",
    "utils/**/*.{ts,tsx}",
    ".storybook/**/*.{ts,tsx}"
  ],
  "include": ["dependencies", "unlisted", "binaries"],
  "ignore": [
    ".output/**",
    ".wxt/**",
    "coverage/**",
    "node_modules/**",
    "playwright-report/**",
    "storybook-static/**",
    "test-results/**",
    "tests-examples/**",
    "start/**"
  ],
  "ignoreFiles": ["stories/**", "tests/**"],
  "ignoreDependencies": [
    "@ai-sdk/react",
    "@wxt-dev/i18n",
    "@storybook/addon-onboarding",
    "@storybook/builder-vite",
    "@testing-library/jest-dom",
    "@vitest/coverage-v8",
    "@types/chrome",
    "@types/node",
    "@types/react",
    "@types/react-dom",
    "@types/webextension-polyfill",
    "autoprefixer",
    "path",
    "postcss"
  ],
  "lefthook": true,
  "playwright": true,
  "storybook": true,
  "vitest": false
}
