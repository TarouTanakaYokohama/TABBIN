{
  "$schema": "./node_modules/knip/schema.json",
  "entry": [
    "src/entrypoints/**/*.{ts,tsx}",
    "src/components/**/*.{test,stories}.{ts,tsx}",
    "src/features/**/*.{test,stories}.{ts,tsx}",
    "src/hooks/**/*.{test,stories}.{ts,tsx}",
    "src/lib/**/*.{test,stories}.{ts,tsx}",
    "src/utils/**/*.{test,stories}.{ts,tsx}",
    "e2e/**/*.{ts,tsx}",
    "tools/**/*.{ts,tsx}",
    ".storybook/**/*.{ts,tsx}",
    "vitest.config.ts",
    "vitest.ci.config.ts",
    "vitest.workspace.ts",
    "wxt.config.ts"
  ],
  "project": [
    "src/components/**/*.{ts,tsx}",
    "src/constants/**/*.ts",
    "src/entrypoints/**/*.{ts,tsx}",
    "e2e/**/*.{ts,tsx}",
    "src/features/**/*.{ts,tsx}",
    "src/hooks/**/*.{ts,tsx}",
    "src/lib/**/*.{ts,tsx}",
    "src/types/**/*.{ts,tsx,d.ts}",
    "src/utils/**/*.{ts,tsx}",
    "tools/**/*.{ts,tsx}",
    ".storybook/**/*.{ts,tsx}"
  ],
  "include": ["dependencies", "unlisted", "binaries"],
  "ignore": [
    ".output/**",
    ".wxt/**",
    "coverage/**",
    "node_modules/**",
    "playwright-report/**",
    "storybook-static/**",
    "test-results/**",
    "tests-examples/**",
    "start/**"
  ],
  "ignoreFiles": ["src/stories/**", "tests/**"],
  "ignoreDependencies": [
    "@ai-sdk/react",
    "@wxt-dev/i18n",
    "@storybook/addon-onboarding",
    "@storybook/builder-vite",
    "@testing-library/jest-dom",
    "@vitest/coverage-v8",
    "@types/chrome",
    "@types/node",
    "@types/react",
    "@types/react-dom",
    "@types/webextension-polyfill",
    "autoprefixer",
    "path",
    "postcss"
  ],
  "lefthook": true,
  "playwright": true,
  "storybook": true,
  "vitest": false
}
