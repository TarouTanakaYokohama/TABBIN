{
  "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
  "extends": [],
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/.output",
      "!**/.wxt",
      "!**/.apm",
      "!**/.agents",
      "!**/.claude",
      "!**/.codex",
      "!**/.cursor",
      "!**/.gemini",
      "!**/.github/hooks",
      "!**/.github/skills",
      "!**/node_modules",
      "!**/apm_modules",
      "!**/coverage",
      "!**/test-results",
      "!**/playwright-report",
      "!**/blob-report",
      "!**/storybook-static",
      "!**/tmp-profile-saved-tabs.cjs"
    ]
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "identifierOrder": "lexicographic",
            "groups": [
              ":NODE:",
              ":PACKAGE_WITH_PROTOCOL:",
              ":PACKAGE:",
              ":ALIAS:",
              ":PATH:"
            ]
          }
        }
      }
    }
  },
  "linter": {
    "enabled": true,
    "includes": [
      "**",
      "!**/.output",
      "!**/.wxt",
      "!**/.apm",
      "!**/.agents",
      "!**/.claude",
      "!**/.codex",
      "!**/.cursor",
      "!**/.gemini",
      "!**/.github/hooks",
      "!**/.github/skills",
      "!**/wxt.config.ts",
      "!**/node_modules",
      "!**/apm_modules",
      "!**/coverage",
      "!**/test-results",
      "!**/playwright-report",
      "!**/blob-report",
      "!**/storybook-static",
      "!**/tmp-profile-saved-tabs.cjs"
    ],
    "rules": {
      "recommended": true,
      "a11y": {
        "recommended": true,
        "noNoninteractiveElementInteractions": "off",
        "useButtonType": "error"
      },
      "complexity": {
        "recommended": true,
        "noExcessiveCognitiveComplexity": {
          "level": "error",
          "options": {
            "maxAllowedComplexity": 15
          }
        },
        "noExcessiveLinesPerFunction": "off",
        "noExtraBooleanCast": "off",
        "noImplicitCoercions": "error",
        "noVoid": "off",
        "useArrowFunction": "error",
        "useMaxParams": {
          "level": "error",
          "options": {
            "max": 4
          }
        },
        "useOptionalChain": "error"
      },
      "correctness": {
        "recommended": true,
        "noNestedComponentDefinitions": "error",
        "noUndeclaredDependencies": "error",
        "noUnresolvedImports": "off",
        "noUnusedFunctionParameters": "error",
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "useExhaustiveDependencies": "off",
        "useImportExtensions": "off",
        "useUniqueElementIds": "off"
      },
      "nursery": {
        "recommended": true,
        "noNestedPromises": "off",
        "useSortedClasses": "error"
      },
      "performance": {
        "recommended": true,
        "noAwaitInLoops": "off",
        "noBarrelFile": "off",
        "noNamespaceImport": "off",
        "noReExportAll": "off",
        "useTopLevelRegex": "off"
      },
      "security": {
        "recommended": true,
        "noSecrets": "off"
      },
      "style": {
        "recommended": true,
        "noCommonJs": "off",
        "noDefaultExport": "off",
        "noExportedImports": "off",
        "noJsxLiterals": "off",
        "noMagicNumbers": "off",
        "noNamespace": "off",
        "noNestedTernary": "error",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "patterns": [
              {
                "group": ["../*"],
                "message": "親ディレクトリ相対ではなく `@/` エイリアスを使用してください"
              }
            ]
          }
        },
        "noProcessEnv": "off",
        "useBlockStatements": "error",
        "useComponentExportOnlyModules": "off",
        "useConsistentArrayType": "error",
        "useConsistentTypeDefinitions": "error",
        "useImportType": "error",
        "useNodejsImportProtocol": "error",
        "useNumericSeparators": "off",
        "useExportsLast": "error",
        "useExplicitLengthCheck": "off",
        "useFilenamingConvention": "off",
        "useNamingConvention": {
          "level": "error",
          "options": {
            "requireAscii": true,
            "strictCase": false,
            "conventions": [
              {
                "selector": {
                  "kind": "variable"
                },
                "formats": ["camelCase", "PascalCase", "CONSTANT_CASE"]
              },
              {
                "selector": {
                  "kind": "objectLiteralMember"
                },
                "formats": ["camelCase", "PascalCase", "CONSTANT_CASE"]
              },
              {
                "selector": {
                  "kind": "typeLike"
                },
                "formats": ["PascalCase"]
              },
              {
                "selector": {
                  "kind": "function"
                },
                "formats": ["camelCase", "PascalCase"]
              }
            ]
          }
        },
        "useSelfClosingElements": "error",
        "useShorthandAssign": "error",
        "useThrowOnlyError": "off"
      },
      "suspicious": {
        "recommended": true,
        "noDoubleEquals": "error",
        "noFocusedTests": "error",
        "noImportCycles": "warn",
        "useAwait": "off"
      }
    },
    "domains": {
      "next": "none",
      "playwright": "all",
      "project": "all",
      "qwik": "none",
      "react": "all",
      "solid": "none",
      "tailwind": "all",
      "test": "all",
      "turborepo": "none",
      "types": "all",
      "vue": "none"
    }
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": true,
    "useEditorconfig": false,
    "lineEnding": "lf",
    "includes": [
      "**",
      "!**/.output",
      "!**/.wxt",
      "!**/.apm",
      "!**/.agents",
      "!**/.claude",
      "!**/.codex",
      "!**/.cursor",
      "!**/.gemini",
      "!**/.github/hooks",
      "!**/.github/skills",
      "!**/wxt.config.ts",
      "!**/node_modules",
      "!**/apm_modules",
      "!**/coverage",
      "!**/test-results",
      "!**/playwright-report",
      "!**/blob-report",
      "!**/storybook-static",
      "!**/tmp-profile-saved-tabs.cjs"
    ],
    "indentWidth": 2,
    "indentStyle": "space",
    "lineWidth": 80
  },
  "javascript": {
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    },
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "single",
      "quoteProperties": "asNeeded",
      "trailingCommas": "all",
      "semicolons": "asNeeded",
      "arrowParentheses": "asNeeded"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": ["components/ai-elements/**"],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off",
            "noImplicitCoercions": "off"
          },
          "security": {
            "noDangerouslySetInnerHtml": "off"
          },
          "style": {
            "useExportsLast": "off",
            "useNamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": ["components/ui/**"],
      "linter": {
        "rules": {
          "a11y": {
            "useKeyWithClickEvents": "off",
            "useSemanticElements": "off"
          },
          "nursery": {
            "useSortedClasses": "off"
          },
          "style": {
            "useConsistentTypeDefinitions": "off",
            "useExportsLast": "off",
            "useImportType": "off"
          },
          "suspicious": {
            "noReactForwardRef": "off"
          }
        }
      }
    }
  ],
  "json": {
    "parser": { "allowComments": true },
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2,
      "lineWidth": 80
    }
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  }
}
