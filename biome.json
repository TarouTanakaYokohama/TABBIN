{
  "$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
  "extends": [],
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/.output",
      "!**/.wxt",
      "!**/node_modules",
      "!**/coverage",
      "!**/test-results",
      "!**/playwright-report",
      "!**/blob-report",
      "!**/storybook-static",
      "!**/tmp-profile-saved-tabs.cjs"
    ]
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "identifierOrder": "lexicographic",
            "groups": [
              ":NODE:",
              ":PACKAGE_WITH_PROTOCOL:",
              ":PACKAGE:",
              ":ALIAS:",
              ":PATH:"
            ]
          }
        }
      }
    }
  },
  "linter": {
    "enabled": true,
    "includes": [
      "**",
      "!**/.output",
      "!**/.wxt",
      "!**/wxt.config.ts",
      "!**/node_modules",
      "!**/coverage",
      "!**/test-results",
      "!**/playwright-report",
      "!**/blob-report",
      "!**/storybook-static",
      "!**/tmp-profile-saved-tabs.cjs"
    ],
    "rules": {
      "recommended": true,
      "a11y": {
        "recommended": true,
        "noNoninteractiveElementInteractions": "off",
        "useButtonType": "error"
      },
      "complexity": {
        "recommended": true,
        "noExcessiveCognitiveComplexity": {
          "level": "error",
          "options": {
            "maxAllowedComplexity": 15
          }
        },
        "noExcessiveLinesPerFunction": "off",
        "noExtraBooleanCast": "off",
        "noImplicitCoercions": "off",
        "noVoid": "off",
        "useMaxParams": "off",
        "useOptionalChain": "error"
      },
      "correctness": {
        "recommended": true,
        "noUndeclaredDependencies": "error",
        "noUnresolvedImports": "off",
        "noUnusedFunctionParameters": "error",
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "useExhaustiveDependencies": "off",
        "useImportExtensions": "off",
        "useUniqueElementIds": "off"
      },
      "nursery": {
        "recommended": true,
        "noNestedPromises": "off",
        "useSortedClasses": "error"
      },
      "performance": {
        "recommended": true,
        "noAwaitInLoops": "off",
        "noBarrelFile": "off",
        "noNamespaceImport": "off",
        "noReExportAll": "off",
        "useTopLevelRegex": "off"
      },
      "security": {
        "recommended": true,
        "noSecrets": "off"
      },
      "style": {
        "recommended": true,
        "noCommonJs": "off",
        "noDefaultExport": "off",
        "noExportedImports": "off",
        "noJsxLiterals": "off",
        "noMagicNumbers": "off",
        "noNamespace": "off",
        "noNestedTernary": "off",
        "noProcessEnv": "off",
        "useBlockStatements": "error",
        "useComponentExportOnlyModules": "off",
        "useConsistentArrayType": "error",
        "useConsistentTypeDefinitions": "error",
        "useImportType": "error",
        "useNodejsImportProtocol": "error",
        "useNumericSeparators": "off",
        "useExportsLast": "off",
        "useExplicitLengthCheck": "off",
        "useFilenamingConvention": "off",
        "useNamingConvention": "off",
        "useThrowOnlyError": "off"
      },
      "suspicious": {
        "recommended": true,
        "noDoubleEquals": "error",
        "noFocusedTests": "error",
        "noImportCycles": "off",
        "useAwait": "off"
      }
    },
    "domains": {
      "next": "none",
      "playwright": "all",
      "project": "all",
      "qwik": "none",
      "react": "all",
      "solid": "none",
      "tailwind": "all",
      "test": "all",
      "turborepo": "none",
      "types": "all",
      "vue": "none"
    }
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": true,
    "useEditorconfig": false,
    "includes": [
      "**",
      "!**/.output",
      "!**/.wxt",
      "!**/wxt.config.ts",
      "!**/node_modules",
      "!**/coverage",
      "!**/test-results",
      "!**/playwright-report",
      "!**/blob-report",
      "!**/storybook-static",
      "!**/tmp-profile-saved-tabs.cjs"
    ],
    "indentWidth": 2,
    "indentStyle": "space",
    "lineWidth": 80
  },
  "javascript": {
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    },
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "single",
      "quoteProperties": "asNeeded",
      "trailingCommas": "all",
      "semicolons": "asNeeded",
      "arrowParentheses": "asNeeded"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "json": {
    "parser": { "allowComments": true },
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2,
      "lineWidth": 80
    }
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  }
}
