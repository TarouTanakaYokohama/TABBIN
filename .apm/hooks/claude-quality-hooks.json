{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "command": "./scripts/track-edit.sh",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "./scripts/stop-verify.sh",
            "timeout": 300,
            "type": "command"
          }
        ]
      }
    ]
  }
}
