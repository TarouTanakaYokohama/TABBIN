{
  "absolute": false,
  "threshold": 0.7,
  "minTokens": 80,
  "reporters": ["console"],
  "gitignore": true,
  "ignore": [
    "**/*.test.*",
    "**/*.spec.*",
    "**/*.stories.*",
    "**/stories/**",
    "**/.storybook/**",
    "**/coverage/**",
    "**/.output/**",
    "**/.wxt/**",
    "**/storybook-static/**",
    "**/playwright-report/**",
    "**/test-results/**",
    "**/node_modules/**",
    "**/tests/**",
    "**/tests-examples/**",
    "**/start/**"
  ],
  "path": [
    "src/components",
    "src/constants",
    "src/entrypoints",
    "src/features",
    "src/hooks",
    "src/lib",
    "src/types",
    "src/utils"
  ]
}
