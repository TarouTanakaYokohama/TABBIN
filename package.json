  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsgo --noEmit",
    "postinstall": "wxt prepare",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "check:duplication": "jscpd --config .jscpd.json",
    "quality": "bun run format && bun run lint && bun run check && bun run test && bun run knip && bun run check:duplication",
    "test": "vitest run --config vitest.ci.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.ci.config.ts",
    "storybook": "BROWSER=none storybook dev -p 6006",
